# Qiita APIトークン (main.pyで使用)
QIITA_TOKEN=your_qiita_api_token
# Slack Incoming Webhook URL (main.pyで使用)
SLACK_WEBHOOK_URL=your_slack_incoming_webhook_url
# Google Gemini APIキー (main.py, rag_bot.pyで使用)
GOOGLE_API_KEY=your_google_gemini_api_key
# Slack Botトークン (rag_bot.pyで使用)
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token
# Slack Appトークン (rag_bot.pyで使用)
SLACK_APP_TOKEN=xapp-your_slack_app_token
# Supabase URL (main.py, rag_bot.pyで使用)
SUPABASE_URL=https://your-project-id.supabase.co
# Supabase Anon Key (main.py, rag_bot.pyで使用)
SUPABASE_KEY=your_supabase_anon_key
# Google Sheets連携用クレデンシャルJSON (main.pyでスプレッドシート連携する場合)
GOOGLE_CREDENTIALS_JSON={"type": "service_account", ...}
# Google Sheetsのスプレッドシートキー (main.pyでスプレッドシート連携する場合)
SPREADSHEET_KEY=your_google_spreadsheet_key
